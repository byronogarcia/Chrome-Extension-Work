{
  "manifest_version": 3,
  "name": "Giva CC Autofill",
  "description": "Inserts user IDs into Customer CC field.",
  "version": "1.0",
  "icons": {
    "16": "images/sante16.png",
    "32": "images/sante32.png",
    "48": "images/sante48.png",
    "128": "images/sante128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "images/sante16.png",
      "32": "images/sante32.png",
      "48": "images/sante48.png",
      "128": "images/sante128.png"
    }
  },
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Fill Customer CC field with user IDs."
    }
  }
}